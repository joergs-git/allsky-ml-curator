# Allsky-ML-Curator — environment configuration
#
# Copy this file to `.env` (which is gitignored) and fill in real values
# before running the app. Never commit `.env` to the repo.

# ---- Supabase (same project as astro-weather) -----------------------------
SUPABASE_URL=https://JOHNDOE.supabase.co
SUPABASE_ANON_KEY=JOHNDOE_anon_key_here
# Optional: service-role key only if admin operations are needed locally
# SUPABASE_SERVICE_KEY=JOHNDOE_service_key_here

# ---- Observatory location (Rheine defaults) -------------------------------
ASTRO_LAT=52.17
ASTRO_LON=7.25
ASTRO_TIMEZONE=Europe/Berlin

# ---- Synology allsky share ------------------------------------------------
# The macOS-side mount path after you connect via Finder (smb://...).
# The app rewrites `/volume1/...` paths from Supabase to this prefix.
ALLSKY_SMB_MOUNT=/Volumes/AllSky-Rheine
ALLSKY_NAS_PATH_PREFIX=/volume1/AllSky-Rheine

# ---- ML runtime (optional tuning) -----------------------------------------
# Minimum human labels before Autonomous Mode may engage
AUTONOMOUS_MIN_LABELS=200
# Per-image confidence threshold below which Autonomous Mode pauses for review
AUTONOMOUS_CONFIDENCE_THRESHOLD=0.6
# Class-5 (clear) weight boost on top of inverse-frequency weighting
CLEAR_CLASS_BOOST=3.0
